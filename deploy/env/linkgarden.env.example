# LinkGarden production environment file.
#
# Install:
#   sudo install -m 0640 -o root -g linkgarden \
#        deploy/env/linkgarden.env.example /etc/linkgarden/linkgarden.env
#   # then edit /etc/linkgarden/linkgarden.env to fill in real secrets
#
# Loaded by the systemd unit via EnvironmentFile=/etc/linkgarden/linkgarden.env.
# pydantic-settings reads these as `Settings` (see app/core/config.py).
#
# Format rules (systemd EnvironmentFile is stricter than a shell .env):
#   - KEY=VALUE per line, no `export`, no command substitution.
#   - Values are taken literally; quotes are kept as part of the value.
#   - Lines starting with `#` are comments.
#
# DO NOT COMMIT the real file. The `.example` here only carries placeholders.

# --- Database --------------------------------------------------------------
# SQLite (default). Path is relative to WorkingDirectory in the systemd unit
# (/srv/linkgarden/backend), so the DB lives at
# /srv/linkgarden/backend/linkgarden.db with WAL/SHM sidecars beside it. WAL,
# foreign_keys=ON, busy_timeout=5000 are set by the SQLAlchemy connect listener.
DATABASE_URL=sqlite+aiosqlite:///./linkgarden.db
#
# Postgres (drop-in swap; install the [postgres] extra in pyproject first):
# DATABASE_URL=postgresql+asyncpg://linkgarden:CHANGEME@127.0.0.1:5432/linkgarden

# --- JWT -------------------------------------------------------------------
# REQUIRED. Generate with: openssl rand -hex 32
# Settings.JWT_SECRET validates length >= 32 and crashes uvicorn loudly on
# startup if missing/short, so a misconfigured host never reaches the first
# request.
JWT_SECRET=REPLACE_ME_WITH_openssl_rand_hex_32_OUTPUT
# 12 hours. Tightening this means more frequent re-logins; loosening it widens
# the blast radius of a stolen token. v1 has no refresh tokens by design.
JWT_TTL_SECONDS=43200

# --- Admin seed (used by alembic 0002_seed_admin) --------------------------
# Only inserted when the users table is empty. On any subsequent boot the
# data migration is a no-op. Rotate via `scripts/seed_admin.py` (interactive,
# reads via getpass) — do not edit hashes here directly.
LG_ADMIN_USERNAME=admin
# REQUIRED to be >= 8 characters. The migration aborts loudly otherwise.
LG_ADMIN_PASSWORD=REPLACE_ME_AT_LEAST_8_CHARS

# --- Static assets ---------------------------------------------------------
# Cover uploads land at <STATIC_DIR>/covers/<card_id>.<ext>. Path is relative
# to WorkingDirectory; nginx `alias /covers/` overrides FastAPI's mount in
# prod, so this directory just needs to be writable by the linkgarden user.
STATIC_DIR=./src/app/static
COVERS_PUBLIC_PREFIX=/covers

# --- CORS ------------------------------------------------------------------
# Empty/omitted in prod: nginx serves the SPA same-origin so there's no
# cross-origin traffic. CORSMiddleware is only registered when APP_ENV=dev.
ALLOWED_ORIGINS=

# --- Runtime mode ----------------------------------------------------------
# `prod` enables JSON structlog output, disables CORSMiddleware, raises log
# level to INFO. `dev` reverses all three.
APP_ENV=prod

# --- Cover upload limits ---------------------------------------------------
# 5 MiB. nginx client_max_body_size is 6 MiB to give the multipart envelope
# some slop; the backend enforces the real cap with a streaming early-abort.
MAX_COVER_BYTES=5242880
# 4096px on either axis. Floor (200x200) is enforced in the service.
MAX_COVER_DIM=4096
