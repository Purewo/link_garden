      "CoverUploadResponse": {
        "additionalProperties": false,
        "description": "Response body for ``POST /api/v1/covers``.\n\nAttributes:\n    ok: Constant ``True`` so success/failure can be branched on a single\n        field without inspecting status codes.\n    url: Public URL of the stored cover (``COVERS_PUBLIC_PREFIX`` +\n        ``/{card_id}.{ext}`` + cache-buster ``?v=<unix-ts>``).\n    width: Decoded pixel width (post-Pillow verify).\n    height: Decoded pixel height.\n    bytes: Final on-disk size in bytes.\n    card: The updated card row, projected through :class:`CardRead`.",
        "properties": {
          "bytes": {
            "minimum": 1.0,
            "title": "Bytes",
            "type": "integer"
          },
          "card": {
            "$ref": "#/components/schemas/CardRead"
          },
          "height": {
            "minimum": 1.0,
            "title": "Height",
            "type": "integer"
          },
          "ok": {
            "const": true,
            "default": true,
            "title": "Ok",
            "type": "boolean"
          },
          "url": {
            "minLength": 1,
            "title": "Url",
            "type": "string"
          },
          "width": {
            "minimum": 1.0,
            "title": "Width",
            "type": "integer"
          }
        },
        "required": [
          "url",
          "width",
          "height",
          "bytes",
          "card"
        ],
        "title": "CoverUploadResponse",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "LoginRequest": {
        "additionalProperties": false,
        "description": "Body of `POST /api/v1/auth/login`.\n\nBounds match the user table widths in §3.3 so over-long inputs are\nrejected with a 422 before they reach bcrypt (which itself truncates at\n72 bytes).",
        "properties": {
          "password": {
            "maxLength": 256,
            "minLength": 1,
            "title": "Password",
            "type": "string"
          },
          "username": {
            "maxLength": 64,
            "minLength": 1,
            "title": "Username",
            "type": "string"
