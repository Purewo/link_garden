      },
      "TokenResponse": {
        "additionalProperties": false,
        "description": "Success body of `POST /api/v1/auth/login`.\n\n`expires_in` is seconds, mirroring the conventional OAuth2 token\nresponse shape so the frontend can store an absolute deadline if it\nwants to.",
        "properties": {
          "access_token": {
            "title": "Access Token",
            "type": "string"
          },
          "expires_in": {
            "title": "Expires In",
            "type": "integer"
          },
          "token_type": {
            "const": "bearer",
            "default": "bearer",
            "title": "Token Type",
            "type": "string"
          },
          "user": {
            "$ref": "#/components/schemas/UserRead"
          }
        },
        "required": [
          "access_token",
          "expires_in",
          "user"
        ],
        "title": "TokenResponse",
        "type": "object"
      },
      "UserRead": {
        "additionalProperties": false,
