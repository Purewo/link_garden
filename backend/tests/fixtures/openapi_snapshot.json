      "CardUpdate": {
        "additionalProperties": false,
        "description": "Admin partial update payload.\n\nEvery field is optional. Omitted fields are preserved by the service so a\nPUT with only ``{title: '…'}`` no longer wipes ``summary``/``cover`` — a\nfix for a documented P1 bug from phase 1.\n\nThe category/url/body coupling is re-checked against the merged result in\nthe service layer, since this schema cannot see the current row.",
        "properties": {
          "body": {
            "anyOf": [
              {
                "maxLength": 262144,
                "type": "string"
              },
              {
                "type": "null"
              }
