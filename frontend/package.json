{
  "name": "linkgarden-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.19"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "gen:api": "tsx scripts/gen-api.ts",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@vueuse/core": "^12.5.0",
    "highlight.js": "^11.11.1",
    "md-editor-v3": "^5.4.1",
    "openapi-fetch": "^0.13.4",
    "pinia": "^3.0.1",
    "pinia-plugin-persistedstate": "^4.2.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^3.0.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^10.0.0",
    "jsdom": "^25.0.1",
    "jiti": "^2.4.2",
    "openapi-typescript": "^7.5.2",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^7.0.0",
    "vite-plugin-checker": "^0.8.0",
    "vitest": "^3.0.0",
    "vue-eslint-parser": "^10.0.0",
    "vue-tsc": "^2.2.0"
  },
  "pnpm": {
    "overrides": {
      "highlight.js": "^11.11.1"
    }
  }
